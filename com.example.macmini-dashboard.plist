<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd service for dashboard.py — install this ONLY on the one machine
  that will host the aggregated dashboard (e.g. one of the Mac minis).

  INSTALL:
    1. Copy dashboard.py to: /opt/homebrew/bin/macmini-dashboard.py
       (create config.json next to it first)
    2. Copy this file to: ~/Library/LaunchAgents/com.example.macmini-dashboard.plist
    3. launchctl load ~/Library/LaunchAgents/com.example.macmini-dashboard.plist
    4. Visit http://<this-machine-tailscale-ip>:8080 from your phone
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.macmini-dashboard</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/opt/homebrew/bin/macmini-dashboard.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/macmini-dashboard.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/macmini-dashboard.err</string>
</dict>
</plist>
